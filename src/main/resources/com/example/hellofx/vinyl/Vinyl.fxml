<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<fx:root type="BorderPane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.hellofx.vinyl.VinylController">

    <center>
        <TableView fx:id="vinylTable">
            <columns>
                <TableColumn fx:id="titleColumn" text="Title" />
                <TableColumn fx:id="artistColumn" text="Artist" />
                <TableColumn fx:id="yearColumn" text="Year" />
                <TableColumn fx:id="stateColumn" text="State" />
            </columns>
        </TableView>
    </center>

    <right>
        <VBox alignment="CENTER" spacing="10">
            <Button onAction="#onReserve" text="Reserve" />
            <Button onAction="#onBorrow" text="Borrow" />
            <Button onAction="#onReturn" text="Return" />
            <Button onAction="#onRemove" text="Remove" />
        </VBox>
    </right>

</fx:root>
